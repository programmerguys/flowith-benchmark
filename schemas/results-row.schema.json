{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/programmerguys/flowith-benchmark/main/schemas/results-row.schema.json",
  "title": "Flowith Benchmark Result Row",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "final_answer",
    "artifacts",
    "trace_refs",
    "duration_ms",
    "attempt_count"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failed",
        "timeout",
        "blocked"
      ]
    },
    "final_answer": {
      "type": [
        "string",
        "number",
        "boolean",
        "object",
        "array",
        "null"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": [
              "path"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "sha256": {
                "type": "string",
                "pattern": "^[A-Fa-f0-9]{64}$"
              }
            }
          }
        ]
      }
    },
    "trace_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "error_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "attempt_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2
    }
  }
}
